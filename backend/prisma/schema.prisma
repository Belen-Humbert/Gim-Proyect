// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  TRAINER
  MEMBER
}

enum PlanStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

// ─────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  firstName    String
  lastName     String
  dni          String?  @unique
  phone        String?
  role         Role     @default(MEMBER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdBy    String?

  trainerProfile  Trainer?
  userPlan        UserPlan?
  routines        Routine[]
  workoutLogs     WorkoutLog[]

  @@map("users")
}

model Trainer {
  id           String   @id @default(uuid())
  userId       String   @unique
  bio          String?
  specialty    String?
  photoUrl     String?
  isVisible    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("trainers")
}

model Plan {
  id           String   @id @default(uuid())
  name         String
  description  String?
  price        Float
  durationDays Int
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userPlans    UserPlan[]

  @@map("plans")
}

model UserPlan {
  id          String     @id @default(uuid())
  userId      String     @unique
  planId      String
  status      PlanStatus @default(ACTIVE)
  startDate   DateTime
  endDate     DateTime
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan        Plan @relation(fields: [planId], references: [id])

  @@map("user_plans")
}

model Routine {
  id          String   @id @default(uuid())
  userId      String   // miembro al que pertenece
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  days        RoutineDay[]

  @@map("routines")
}

model RoutineDay {
  id          String   @id @default(uuid())
  routineId   String
  dayNumber   Int      // 1, 2, 3, 4...
  name        String   // "Día 1 - Pecho y Tríceps"
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  routine     Routine           @relation(fields: [routineId], references: [id], onDelete: Cascade)
  exercises   RoutineExercise[]
  workoutLogs WorkoutLog[]

  @@map("routine_days")
}

model RoutineExercise {
  id           String  @id @default(uuid())
  routineDayId String
  name         String
  sets         Int?
  reps         String? // "10-12" o "Al fallo"
  weight       String? // "20kg" o "Corporal"
  restSeconds  Int?
  notes        String?
  order        Int     @default(0)

  routineDay  RoutineDay @relation(fields: [routineDayId], references: [id], onDelete: Cascade)

  @@map("routine_exercises")
}

model WorkoutLog {
  id           String   @id @default(uuid())
  userId       String
  routineDayId String
  completedAt  DateTime
  notes        String?
  createdAt    DateTime @default(now())

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  routineDay  RoutineDay @relation(fields: [routineDayId], references: [id], onDelete: Cascade)

  @@unique([userId, routineDayId])
  @@map("workout_logs")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}
